APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000

# Supported corpus profiles: sample, public_226. Default sample keeps startup small.
CORPUS_PROFILE=sample
ARTIFACT_DIR=artifacts/index
PUBLIC_226_ARTIFACT_DIR=data/public_corpus_226
# Supported modes: mock, gemini, gemma, groq, ollama. Mock is the no-key default.
LLM_MODE=mock
# Gemma mode requires an available Gemma model ID from Google AI Studio / Gemini API.
MODEL_NAME=mock-local

# Used by both gemini and gemma modes.
GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LLM_TIMEOUT_SECONDS=300

DEFAULT_TOP_K=5
DEFAULT_RETRIEVAL_MODE=hybrid
ENABLE_DEBUG=true
ENABLE_SEMANTIC_GATE=false
